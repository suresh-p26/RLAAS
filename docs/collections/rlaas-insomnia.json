        "text": "{\n  \"policy_id\": \"payments-limit\",\n  \"name\": \"Payments limit\",\n  \"enabled\": true,\n  \"priority\": 100,\n  \"scope\": {\n    \"org_id\": \"acme\",\n    \"signal_type\": \"http\",\n    \"operation\": \"charge\"\n  },\n  \"algorithm\": {\n    \"type\": \"fixed_window\",\n    \"limit\": 100,\n    \"window\": \"1m\"\n  },\n  \"action\": \"deny\",\n  \"failure_mode\": \"fail_open\",\n  \"enforcement_mode\": \"enforce\",\n  \"rollout_percent\": 100\n}"
      }
