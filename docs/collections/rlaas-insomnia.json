      "body": {
        "mimeType": "application/json",
        "text": "{\n  \"request_id\": \"req-1\",\n  \"org_id\": \"acme\",\n  \"tenant_id\": \"retail\",\n  \"signal_type\": \"http\",\n  \"operation\": \"charge\",\n  \"endpoint\": \"/v1/charge\",\n  \"method\": \"POST\",\n  \"user_id\": \"u1\",\n  \"tags\": { \"env\": \"production\" }\n}"
      }
    },
